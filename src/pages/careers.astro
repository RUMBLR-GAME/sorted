---
import Base from '@/layouts/Base.astro';

const title = 'Careers — Sorted';
const description = "We're a small team in Brisbane building Australia's next P2P payments app. Hiring engineers, designers, and ops.";
---

<Base title={title} description={description}>
<section class="subhero dotgrid">
  <div class="container">
    <div class="crumbs"><a href="/">Sorted</a><span class="sep"></span><span>Company</span><span class="sep"></span><span>Careers</span></div>
    <span class="subhero-eyebrow">Company · Careers</span>
    <h1>Build money the way it <span class="hl">should've worked.</span></h1>
    <p class="subhero-sub">Small Brisbane team. Big ambition. We're hiring across engineering, design, ops, and risk. <strong>Remote-friendly within Australia,</strong> in-person preferred for senior roles.</p>
  </div>
</section>
<section class="section reveal"><div class="container">
    <div class="prose">
      <h2>Why work here.</h2>
      <p>Most fintech work is incremental — adding a feature to a product that already exists. Sorted is the rare opportunity to <strong>rebuild Australian peer-to-peer payments from the rails up</strong>. The technical scope is wide (regulated deposits, real-time settlement, mobile-grade UX), the team is small enough that you'll ship things people actually use within your first month, and the rate of "I just shipped that and a real person used it five minutes later" is the highest you'll find anywhere.</p>
      <h2>What we offer.</h2>
      <ul>
        <li><strong>Real equity, real cash.</strong> We pay market salaries; we don't ask you to subsidise the seed round.</li>
        <li><strong>Brisbane HQ, remote-friendly.</strong> WFH any day, in-office Tuesdays and Thursdays for the synchronous bits.</li>
        <li><strong>Hardware budget.</strong> Whatever laptop you want, plus standing desk / monitor / chair if working from home.</li>
        <li><strong>Real superannuation matching.</strong> 12%, not the legal minimum.</li>
        <li><strong>Time off you actually take.</strong> 5 weeks annual + 2-week shutdown over Christmas. Founders take theirs first.</li>
        <li><strong>L&D budget.</strong> $3k/year for whatever helps you ship better.</li>
      </ul>
    </div>
    </div></section><section class="section alt reveal"><div class="container">
    <div class="section-head"><span class="section-eyebrow">Open roles</span><h2 class="section-title">We're <span class="hl">hiring.</span></h2></div>
    <div class="card-grid" style="max-width:1080px;margin:0 auto;">
      <a class="tile-card" href="mailto:jobs@sortedaud.app?subject=Senior%20Mobile%20Engineer">
        <span class="tile-card-tag">Engineering</span>
        <h3 class="tile-card-title">Senior Mobile Engineer (iOS or Android)</h3>
        <p class="tile-card-desc">Lead the next generation of the Sorted mobile experience. Native Swift / Kotlin. Strong product sensibility required.</p>
        <div class="tile-card-meta">Brisbane · Full-time</div>
      </a>
      <a class="tile-card coral" href="mailto:jobs@sortedaud.app?subject=Backend%20Engineer">
        <span class="tile-card-tag">Engineering</span>
        <h3 class="tile-card-title">Backend Engineer (Rust / Solana)</h3>
        <p class="tile-card-desc">Own the AUDD ↔ wallet pipeline. Solana program experience preferred but we'll teach the rest.</p>
        <div class="tile-card-meta">Brisbane / remote-AU · Full-time</div>
      </a>
      <a class="tile-card sky" href="mailto:jobs@sortedaud.app?subject=Product%20Designer">
        <span class="tile-card-tag">Design</span>
        <h3 class="tile-card-title">Product Designer</h3>
        <p class="tile-card-desc">Hold the design system, ship interfaces that work for people who've never touched crypto. Mobile-first portfolio essential.</p>
        <div class="tile-card-meta">Brisbane · Full-time</div>
      </a>
      <a class="tile-card butter" href="mailto:jobs@sortedaud.app?subject=Compliance%20Lead">
        <span class="tile-card-tag">Risk & Compliance</span>
        <h3 class="tile-card-title">Compliance Lead</h3>
        <p class="tile-card-desc">Own AFSL/AUSTRAC obligations, build the second-line risk function. AML/CTF experience required.</p>
        <div class="tile-card-meta">Brisbane · Full-time</div>
      </a>
      <a class="tile-card" href="mailto:jobs@sortedaud.app?subject=Customer%20Operations">
        <span class="tile-card-tag">Operations</span>
        <h3 class="tile-card-title">Customer Operations</h3>
        <p class="tile-card-desc">Be the human behind support. Set the standard for honest, fast responses. Money / fintech background a plus.</p>
        <div class="tile-card-meta">Brisbane · Full-time</div>
      </a>
      <a class="tile-card coral" href="mailto:jobs@sortedaud.app?subject=Don't%20see%20your%20role">
        <span class="tile-card-tag">Open application</span>
        <h3 class="tile-card-title">Don't see your role?</h3>
        <p class="tile-card-desc">Send us a one-page note about what you do well and what you want to build. We read everything.</p>
        <div class="tile-card-meta">Always open</div>
      </a>
    </div></div></section>
<section class="page-cta">
  <div class="container">
    <div class="page-cta-inner reveal">
      <h2 class="page-cta-title">Apply.</h2>
      <p class="page-cta-sub">Tell us a story about something you shipped that you're proud of. We'll write back.</p>
      <div class="page-cta-actions">
        <a data-claim href="#" class="btn btn-dark btn-lg">Claim your handle <svg class="icon"><use href="#i-arrow-right"/></svg></a>
        <a href="/how-it-works" class="btn btn-secondary btn-lg">Read the blog</a>
      </div>
    </div>
  </div>
</section>
</Base>
