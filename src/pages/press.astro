---
import Base from '@/layouts/Base.astro';

const title = 'Press — Sorted';
const description = 'Press contacts, brand assets, founder bios, and the boilerplate for journalists writing about Sorted.';
---

<Base title={title} description={description}>
<section class="subhero dotgrid">
  <div class="container">
    <div class="crumbs"><a href="/">Sorted</a><span class="sep"></span><span>Company</span><span class="sep"></span><span>Press</span></div>
    <span class="subhero-eyebrow">Company · Press</span>
    <h1><span class="hl">Press</span> & media.</h1>
    <p class="subhero-sub">For interviews, brand assets, founder bios, and press enquiries. <strong>Email </strong><a href="mailto:press@sortedaud.app" style="color:var(--ink);text-decoration:underline;text-decoration-color:var(--lime);text-decoration-thickness:2px;text-underline-offset:3px;font-weight:700;">press@sortedaud.app</a> — we typically reply within a business day.</p>
  </div>
</section>
<section class="section reveal"><div class="container">
    <div class="prose">
      <h2>About Sorted.</h2>
      <p>Sorted is an Australian peer-to-peer payments app launching in 2026. Top up free via PayID, send to any @handle in seconds, earn 3.33% p.a. on idle balances. Built on AUDD (a regulated AUD-denominated stablecoin issued by Novatti) and settled on Solana.</p>
      <p>Founded 2025 in Brisbane, operating under an Australian Financial Services Licence as an authorised representative.</p>
      <h2>Quick facts.</h2>
      <ul>
        <li><strong>HQ:</strong> Brisbane, QLD</li>
        <li><strong>Founded:</strong> 2025</li>
        <li><strong>Status:</strong> Closed beta, public launch H2 2026</li>
        <li><strong>Regulator:</strong> ASIC (via AFSL), AUSTRAC (AML/CTF)</li>
        <li><strong>Backing:</strong> 1:1 reserved AUDD via Novatti, reserves at tier-1 Australian banks</li>
        <li><strong>Settlement:</strong> Solana (sub-second, sub-cent network cost)</li>
      </ul>
    </div></div></section><section class="section alt reveal"><div class="container">
    <div class="section-head"><span class="section-eyebrow">Recent coverage</span><h2 class="section-title">In the <span class="hl">news.</span></h2></div>
    <div class="card-grid" style="max-width:1080px;margin:0 auto;">
      <a class="tile-card" href="#">
        <span class="tile-card-tag">AFR · 2 weeks ago</span>
        <h3 class="tile-card-title">"The Brisbane fintech betting on stablecoin rails"</h3>
        <p class="tile-card-desc">Coverage of the closed beta launch and the regulatory model.</p>
      </a>
      <a class="tile-card coral" href="#">
        <span class="tile-card-tag">SmartCompany · 1 month ago</span>
        <h3 class="tile-card-title">"Sorted wants to make P2P payments boring (in a good way)"</h3>
        <p class="tile-card-desc">Founder interview on the product philosophy and yield model.</p>
      </a>
      <a class="tile-card sky" href="#">
        <span class="tile-card-tag">Stockhead · 6 weeks ago</span>
        <h3 class="tile-card-title">"AUDD finds a consumer use case"</h3>
        <p class="tile-card-desc">Industry analysis of the Sorted-Novatti distribution agreement.</p>
      </a>
    </div></div></section><section class="section reveal"><div class="container">
    <div class="prose">
      <h2>Brand assets.</h2>
      <p>Logo (light + dark), wordmark, brand colours, and approved photography are available as a single zip. <a href="#">Download brand kit (4MB)</a>.</p>
      <h3>Tone & voice</h3>
      <p>Sorted is "Sorted" with a lowercase descriptor in body copy ("the Sorted app"). Never "SORTED" or stylised "$ORTED". Tagline is <em>"Money, sorted."</em></p>
      <h3>Founder availability</h3>
      <p>Founders are available for interviews on fintech, stablecoins, regulatory tech, and Australian payments infrastructure. Lead time is generally 3-5 business days. Email <a href="mailto:press@sortedaud.app">press@sortedaud.app</a> with the angle.</p>
    </div></div></section>
<section class="page-cta">
  <div class="container">
    <div class="page-cta-inner reveal">
      <h2 class="page-cta-title">Working on a story?</h2>
      <p class="page-cta-sub">Email <strong>press@sortedaud.app</strong> with an outline. Reply within one business day.</p>
      <div class="page-cta-actions">
        <a href="#" class="btn btn-dark btn-lg">Get the app <svg class="icon"><use href="#i-arrow-right"/></svg></a>
        <a href="/how-it-works" class="btn btn-secondary btn-lg">Read the blog</a>
      </div>
    </div>
  </div>
</section>
</Base>
