---
import Base from '@/layouts/Base.astro';
import Marquee from '@/components/Marquee.astro';
import PageCTA from '@/components/PageCTA.astro';
import SectionDivider from '@/components/SectionDivider.astro';
import StickerMark from '@/components/StickerMark.astro';
import P2PAnimation from '@/components/P2PAnimation.astro';

const title = 'Sorted — Money, sorted. Free. Instant. Earning 3.33%.';
const description = 'The Australian peer-to-peer payments app. Top up free, send to any @handle in seconds, earn 3.33% p.a. on every dollar still. Built on AUDD, settled on Solana.';
---

<Base title={title} description={description}>

<section class="hero dotgrid dotgrid-hero">
  <div class="container hero-grid">
    <div>
      <h1 class="hero-title">
        Money,<br><span class="hl">sorted.</span>
      </h1>
      <p class="hero-sub">
        Send to any <strong>@handle</strong>, anywhere in Australia. <strong>Free. Instant. Done.</strong>
      </p>
      <div class="hero-actions">
        <a data-claim href="#" class="btn btn-primary btn-lg">Claim your handle <svg class="icon"><use href="#i-arrow-right"/></svg></a>
        <a href="/how-it-works" class="btn btn-secondary btn-lg">How it works</a>
      </div>
      <div class="hero-trust">
        <div class="trust-item">
          <div class="trust-num"><span data-count="0" data-prefix="$">$0</span></div>
          <div class="trust-label">Send. Receive.<br>Top up. Forever.</div>
        </div>
        <div class="trust-item">
          <div class="trust-num"><span data-count="2" data-prefix="<" data-decimals="0">&lt;2</span><span class="unit">sec</span></div>
          <div class="trust-label">From tap<br>to balance</div>
        </div>
        <div class="trust-item">
          <div class="trust-num">24/7</div>
          <div class="trust-label">Saturday night,<br>Christmas morning</div>
        </div>
      </div>
    </div>

    <div class="hero-visual">
      <div class="phone">
        <div class="phone-notch"></div>
        <div class="phone-screen">
          <div class="phone-status"><span>9:41</span><span>● ● ●</span></div>
          <div class="phone-header">
            <div class="ph-greet-block">
              <span class="ph-handle">@hannah</span>
              <span class="ph-greeting">G'day, Hannah</span>
            </div>
            <div class="ph-bell"><svg class="icon"><use href="#i-bell"/></svg></div>
          </div>
          <div class="ph-balance">
            <div class="ph-balance-label">Available balance</div>
            <div class="ph-balance-amt">$1,247<span class="cents">.50</span><span class="ccy">AUD</span></div>
            <div class="ph-earn-pill"><span class="live-tick"></span> Earning 3.33% p.a.</div>
          </div>
          <div class="ph-actions">
            <div class="ph-action">
              <div class="ph-action-icon send"><svg class="icon"><use href="#i-send"/></svg></div>
              <span class="ph-action-label">Send</span>
            </div>
            <div class="ph-action">
              <div class="ph-action-icon receive"><svg class="icon"><use href="#i-receive"/></svg></div>
              <span class="ph-action-label">Receive</span>
            </div>
            <div class="ph-action">
              <div class="ph-action-icon topup"><svg class="icon"><use href="#i-plus"/></svg></div>
              <span class="ph-action-label">Top up</span>
            </div>
          </div>
          <div class="ph-section-label">Recent</div>
          <div class="ph-activity-row">
            <div class="ph-act-avatar a1">MT</div>
            <div class="ph-act-info">
              <div class="ph-act-name">Maya Thompson</div>
              <div class="ph-act-meta">@maya · 2 min ago</div>
            </div>
            <div class="ph-act-amt out">−$24.00</div>
          </div>
          <div class="ph-activity-row">
            <div class="ph-act-avatar a2">JL</div>
            <div class="ph-act-info">
              <div class="ph-act-name">Jack Lawson</div>
              <div class="ph-act-meta">@jackl · 18 min ago</div>
            </div>
            <div class="ph-act-amt in">+$85.00</div>
          </div>
          <div class="ph-activity-row">
            <div class="ph-act-avatar a3">DY</div>
            <div class="ph-act-info">
              <div class="ph-act-name">Daily yield</div>
              <div class="ph-act-meta">Paid today · 9:00 am</div>
            </div>
            <div class="ph-act-amt in">+$0.11</div>
          </div>
        </div>
      </div>
      <div class="float-card float-card-1">
        <div class="float-icon lime"><svg class="icon"><use href="#i-zap"/></svg></div>
        <div>
          <div class="float-text">$50 sent</div>
          <div class="float-sub">Settled in 1.4s</div>
        </div>
      </div>
      <div class="float-card float-card-2">
        <div class="float-icon coral"><svg class="icon"><use href="#i-trending"/></svg></div>
        <div>
          <div class="float-text">+$0.11 earned</div>
          <div class="float-sub">Paid daily · auto</div>
        </div>
      </div>
    </div>
  </div>
</section>

<Marquee
  bgAbove="var(--paper)"
  bgBelow="var(--paper)"
  ribbon="var(--butter)"
  ink="var(--ink)"
  phrases={[
    'FREE FOREVER',
    'INSTANT',
    'NO BSB',
    'NO FEES',
    'NO DRAMA',
    'BUILT IN AUSTRALIA',
  ]}
/>

<!-- Why Sorted -->
<section class="why-us reveal" id="why">
  <div class="container">
    <div class="section-head">
      <h2 class="section-title">Built for the everyday <span class="hl">P2P bit.</span></h2>
      <p class="section-sub">Shouting Maccas. Paying your mate back. Sending Mum a hundred for her birthday. None of it should cost you a cent.</p>
    </div>

    <P2PAnimation />

    <div class="usp-stack">
      <div class="usp-card featured">
        <h3 class="usp-headline">Free. Instant. <span class="stress">Done.</span></h3>
        <p class="usp-body">
          Type a handle, slide to send. Lands in their account before you've put your phone down. Saturday night, Boxing Day, 3am on a Tuesday — same speed, zero cost. No BSB. No "pending until tomorrow". No card surcharge buried at the bottom of the screen.
        </p>
        <div class="usp-vs">
          <div>
            <span class="usp-vs-label">Bank transfer</span>
            <span class="usp-vs-val them">1–3 days</span>
          </div>
          <div>
            <span class="usp-vs-label">Sorted</span>
            <span class="usp-vs-val us">&lt;2 seconds</span>
          </div>
          <div>
            <span class="usp-vs-label">PayPal fee</span>
            <span class="usp-vs-val them">2.6% + 30¢</span>
          </div>
          <div>
            <span class="usp-vs-label">Sorted fee</span>
            <span class="usp-vs-val us">$0</span>
          </div>
        </div>
      </div>

      <div class="usp-card">
        <h3 class="usp-headline">No BSBs. <span class="stress">No drama.</span></h3>
        <p class="usp-body">Every account has a <strong>@handle</strong>. Short, memorable, yours. No more texting Mum for her account number for the fifth time.</p>
      </div>

      <div class="usp-card">
        <h3 class="usp-headline">Crypto under the hood. <span class="stress">Not in your face.</span></h3>
        <p class="usp-body">No wallets. No seed phrases. No "what's gas?". Sign in with your number, you're done. The Solana bit is our problem, not yours.</p>
      </div>

      <div class="usp-card">
        <h3 class="usp-headline">Real Aussie dollars. <span class="stress">Real Aussie banks.</span></h3>
        <p class="usp-body">Every dollar's backed 1:1 by AUDD, issued by Novatti under an Australian Financial Services Licence. Reserves in tier-1 banks at home — not offshore.</p>
      </div>

      <div class="usp-card">
        <h3 class="usp-headline">Oh, and your balance <span class="stress">earns 3.33%.</span></h3>
        <p class="usp-body">Money sitting in Sorted earns yield, paid daily. No tier, no minimum, no lock-up. <a href="#earn" class="audd-link">More on that below →</a></p>
      </div>
    </div>
  </div>
</section>

<!-- How it works -->
<section class="how-section reveal" id="how">
  <div class="container">
    <div class="section-head">
      <h2 class="section-title">Easy as. <span class="hl">Three taps.</span></h2>
      <p class="section-sub">Whether it's a $5 coffee debt or splitting rent with three flatmates — same flow, same speed, same zero fees.</p>
    </div>
    <div class="how-grid reveal-stagger">
      <div class="how-step">
        <div class="how-icon"><svg class="icon"><use href="#i-plus"/></svg></div>
        <div class="how-num">01</div>
        <h3 class="how-title">Top up free</h3>
        <p class="how-desc">Link your bank once. Move money in instantly via PayID. No card surcharge, no "1% loading fee".</p>
      </div>
      <div class="how-step">
        <div class="how-icon"><svg class="icon"><use href="#i-at"/></svg></div>
        <div class="how-num">02</div>
        <h3 class="how-title">Send to @anyone</h3>
        <p class="how-desc">Type a handle, slide to send. Lands in under two seconds. Saturday night, Christmas morning, doesn't matter.</p>
      </div>
      <div class="how-step">
        <div class="how-icon"><svg class="icon"><use href="#i-trending"/></svg></div>
        <div class="how-num">03</div>
        <h3 class="how-title">Earn while you wait</h3>
        <p class="how-desc">Anything sitting in your balance earns 3.33% p.a., paid every morning at 9am. No tier, no hoops.</p>
      </div>
    </div>
  </div>
</section>

<SectionDivider bgAbove="var(--ink)" bgBelow="var(--paper)" ribbon="var(--coral)" ink="var(--ink)" label="EARN · 3.33% · DAILY · NO LOCK-UP" />

<!-- Earn — live ticker -->
<section class="earn-section dotgrid reveal" id="earn">
  <div class="container">
    <div class="earn-grid">
      <div class="earn-copy">
        <h2>Always <span class="hl">earning.</span></h2>
        <p>Same model the neobanks use. Your reserves earn ~4% at tier-1 Aussie banks; we pass most of it back. Watch it tick up live.</p>
        <ul class="earn-bullets">
          <li>
            <span class="check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="20 6 9 17 4 12"/></svg></span>
            <span><strong>Paid daily at 9am.</strong> Not monthly. Not "when you reach the threshold".</span>
          </li>
          <li>
            <span class="check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="20 6 9 17 4 12"/></svg></span>
            <span><strong>No lock-up. No minimum.</strong> Spend or send any second.</span>
          </li>
          <li>
            <span class="check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="20 6 9 17 4 12"/></svg></span>
            <span><strong>Same rate for everyone.</strong> No tiers. No "introductory" rates. 3.33%, full stop.</span>
          </li>
        </ul>
      </div>

      <div class="earn-card spring-in">
        <div class="earn-card-eyebrow"><span class="live"></span> Earned so far on $1,000</div>
        <div class="earn-ticker"><span class="symbol">$</span><span data-ticker data-principal="1000" data-apr="0.0333" data-base="12.4837">12.4837</span></div>
        <div class="earn-rate-pill"><span class="dot"></span> 3.33% p.a. · Live</div>
        <div class="earn-stats-grid">
          <div class="earn-stat">
            <div class="earn-stat-label"><span class="live"></span> Today</div>
            <div class="earn-stat-num" data-ticker-today>$0.0625</div>
          </div>
          <div class="earn-stat">
            <div class="earn-stat-label">Per year</div>
            <div class="earn-stat-num"><span data-count="33.30" data-prefix="$" data-decimals="2">$33.30</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Big statement -->
<section class="statement-section reveal">
  <div class="container">
    <div class="statement-block">
      <h2 class="big-quote">
        <span class="word w-lime">FAST.</span>
        <span class="word w-coral">FREE.</span>
        <span class="word w-sky">SORTED.</span>
      </h2>
      <p class="section-sub" style="font-size: 20px;">No fees. No BSBs. No three-day waits. Just send.</p>
      <div class="statement-stats">
        <div class="ss-cell">
          <div class="ss-num"><span data-count="0" data-prefix="$">$0</span></div>
          <div class="ss-label">Fees to send, receive, top up, or hold</div>
        </div>
        <div class="ss-cell">
          <div class="ss-num"><span data-count="1.4" data-decimals="1">1.4</span><span class="unit"> sec</span></div>
          <div class="ss-label">Average tap-to-balance time</div>
        </div>
        <div class="ss-cell">
          <div class="ss-num">24/7</div>
          <div class="ss-label">Saturday night, Boxing Day, 3am</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Trust -->
<section class="trust-section reveal">
  <div class="container">
    <div class="trust-grid">
      <div class="trust-section-copy">
        <h2>Fair dinkum <span class="hl hl-sky">AUD.</span></h2>
        <p>Your balance is backed 1:1 by AUDD, the Australian dollar token issued by Novatti under an Australian Financial Services Licence. Reserves sit in <strong>tier-1 Aussie banks</strong>. Real dollars. Real banks. Real Australia.</p>
        <p>Solana's just the rails — fast, cheap, invisible. It's what makes the under-two-second sends possible. You'll never see it.</p>
        <p style="margin-top: 24px;"><a href="https://audd.digital" target="_blank" rel="noopener" class="audd-link">More about AUDD →</a></p>
      </div>
      <div class="trust-card">
        <div class="trust-row">
          <div class="trust-row-icon"><svg class="icon"><use href="#i-shield"/></svg></div>
          <div class="trust-row-body">
            <div class="trust-row-title">AFSL-regulated</div>
            <div class="trust-row-desc">AUDD is issued by Novatti under an Australian Financial Services Licence.</div>
          </div>
        </div>
        <div class="trust-row">
          <div class="trust-row-icon"><svg class="icon"><use href="#i-lock"/></svg></div>
          <div class="trust-row-body">
            <div class="trust-row-title">1:1 backed</div>
            <div class="trust-row-desc">Every dollar is a real Australian dollar, redeemable any time.</div>
          </div>
        </div>
        <div class="trust-row">
          <div class="trust-row-icon"><svg class="icon"><use href="#i-globe"/></svg></div>
          <div class="trust-row-body">
            <div class="trust-row-title">Reserves at home</div>
            <div class="trust-row-desc">Tier-1 Aussie banks, not offshore. Earning the RBA cash rate.</div>
          </div>
        </div>
        <div class="trust-row">
          <div class="trust-row-icon"><svg class="icon"><use href="#i-zap"/></svg></div>
          <div class="trust-row-body">
            <div class="trust-row-title">Solana rails</div>
            <div class="trust-row-desc">Sub-second settlement, fractions of a cent in network cost. We cover it.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<SectionDivider bgAbove="var(--paper)" bgBelow="var(--paper-deep)" ribbon="var(--sky)" ink="var(--ink)" label="GOT QUESTIONS · WE'VE GOT ANSWERS" />

<!-- FAQ -->
<section class="faq-section reveal" id="faq">
  <div class="container">
    <div class="section-head">
      <h2 class="section-title">Got <span class="hl hl-coral">questions?</span></h2>
      <p class="section-sub">No legalese. No fine print. Just the good oil.</p>
    </div>
    <div class="faq-list">
      <details class="faq-item">
        <summary class="faq-q">How fast is "instant"?<span class="faq-chevron"><svg><use href="#i-chevron-down"/></svg></span></summary>
        <div class="faq-a">Under two seconds, tap to balance. Not "next business day". Not "between 1–3 business days". Two seconds. Saturday night, Boxing Day, 3am on a Tuesday — same speed.</div>
      </details>
      <details class="faq-item">
        <summary class="faq-q">Do I need a wallet or anything crypto-y?<span class="faq-chevron"><svg><use href="#i-chevron-down"/></svg></span></summary>
        <div class="faq-a">Nope. Sign in with your phone, pick a <strong>@handle</strong>, you're in. The Solana settlement layer is just plumbing — same way you don't think about TCP/IP when you send a text. We do the boring bits so you can just send money.</div>
      </details>
      <details class="faq-item">
        <summary class="faq-q">How does the free model actually work?<span class="faq-chevron"><svg><use href="#i-chevron-down"/></svg></span></summary>
        <div class="faq-a">Same model Wise and Revolut use. Your AUD sits in tier-1 Aussie banks earning interest. We earn the spread between what those banks pay and what we pay you, and that runs the whole show. <strong>You never pay a cent in fees.</strong> Send. Receive. Top up. All free, forever.</div>
      </details>
      <details class="faq-item">
        <summary class="faq-q">Where's my money actually kept?<span class="faq-chevron"><svg><use href="#i-chevron-down"/></svg></span></summary>
        <div class="faq-a">In <strong>tier-1 Australian bank accounts</strong>, backed 1:1 by AUDD — an Australian dollar token issued by Novatti under an Australian Financial Services Licence. Your balance is always redeemable for real AUD, any time. Not offshore. Not in stablecoins of stablecoins. Real Aussie dollars in real Aussie banks.</div>
      </details>
      <details class="faq-item">
        <summary class="faq-q">What about the 3.33% — is it real?<span class="faq-chevron"><svg><use href="#i-chevron-down"/></svg></span></summary>
        <div class="faq-a">Real, paid daily at 9am, on every dollar in your balance. No tier, no minimum, no lock-up. The rate tracks the RBA cash rate — when the RBA moves, we move with it, fairly and openly. Right now the RBA's at 4.10%, which makes 3.33% comfortable.</div>
      </details>
      <details class="faq-item">
        <summary class="faq-q">Can I send overseas?<span class="faq-chevron"><svg><use href="#i-chevron-down"/></svg></span></summary>
        <div class="faq-a">Not yet — but soon. We're nailing Aussie P2P first. International sends and a debit card are on the way later this year. Sign up to be first in line.</div>
      </details>
      <details class="faq-item">
        <summary class="faq-q">How do I get money in and out?<span class="faq-chevron"><svg><use href="#i-chevron-down"/></svg></span></summary>
        <div class="faq-a"><strong>PayID, instantly.</strong> Top up: send from your bank to your Sorted PayID, lands in seconds. Cash out: send back to your bank, same speed, same zero cost. No card surcharges, no "1% loading fee" hiding at the bottom of the screen.</div>
      </details>
      <details class="faq-item">
        <summary class="faq-q">Who's making this?<span class="faq-chevron"><svg><use href="#i-chevron-down"/></svg></span></summary>
        <div class="faq-a">A small Aussie team based in Brisbane, who got fed up with money taking three days to move between mates. We operate as an authorised representative under an Australian Financial Services Licence — proper compliance, not a "we'll sort it later" hack.</div>
      </details>
    </div>
  </div>
</section>

<Marquee
  bgAbove="var(--paper-deep)"
  bgBelow="var(--paper)"
  ribbon="var(--lime)"
  ink="var(--ink)"
  phrases={[
    "SEND THAT CASH MATE",
    "DW BRO IT'S SORTED",
    "EASY MONEY",
    "SWEET AS",
    "TOO EASY",
    "ALL GOOD",
  ]}
/>

<div class="cta-stage">
  <StickerMark color="var(--coral)" size="160px" rotate={-12} class="cta-sticker cta-sticker--left" />
  <StickerMark color="var(--lime)" size="180px" rotate={14} class="cta-sticker cta-sticker--right" />
  <PageCTA
    title="Right then.<br>Claim your <span class='hl'>@handle.</span>"
    sub="Takes 90 seconds. No card. No catch. Send your first $20 in the same minute you sign up."
    primaryLabel="Claim your handle"
    secondaryLabel="How it works"
    secondaryHref="/how-it-works"
  />
</div>

</Base>

<style>
  /* ========== LANDING PAGE STYLES ========== */
  .hero {
    padding: 80px 0 120px;
    position: relative;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 2;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    background: var(--lime);
    padding: 8px 14px;
    border-radius: 100px;
    border: 2px solid var(--ink);
    box-shadow: 0 2px 0 var(--ink);
    margin-bottom: 24px;
    animation: fadeUp 700ms var(--ease-smooth) both;
    transform: rotate(-1.5deg);
  }
  .badge .pulse-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--ink);
    animation: pulse 1.4s ease-in-out infinite;
  }
  .hero-eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin-bottom: 16px;
    animation: fadeUp 700ms var(--ease-smooth) 30ms both;
  }
  h1.hero-title {
    font-family: var(--font-display);
    font-size: clamp(72px, 11vw, 168px);
    line-height: 0.88;
    letter-spacing: -0.05em;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 32px;
    animation: fadeUp 800ms var(--ease-smooth) 80ms both;
  }
  h1.hero-title .hl {
    position: relative;
    display: inline-block;
    z-index: 1;
    padding: 0 12px;
    color: var(--ink);
  }
  h1.hero-title .hl::before {
    content: '';
    position: absolute;
    inset: 6% -2% 6% -2%;
    background: var(--lime);
    z-index: -1;
    transform: skewX(-4deg) rotate(-1.5deg);
    border-radius: 12px;
  }
  .hero-sub {
    font-size: 21px;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 520px;
    margin-bottom: 44px;
    font-weight: 450;
    animation: fadeUp 800ms var(--ease-smooth) 180ms both;
  }
  .hero-sub strong { color: var(--ink); font-weight: 700; }
  .hero-actions {
    display: flex;
    gap: 12px;
    margin-bottom: 64px;
    flex-wrap: wrap;
    animation: fadeUp 800ms var(--ease-smooth) 280ms both;
  }
  .hero-trust {
    display: flex;
    gap: 28px;
    align-items: center;
    flex-wrap: wrap;
    padding-top: 28px;
    border-top: 2px dashed var(--line);
    animation: fadeUp 800ms var(--ease-smooth) 380ms both;
  }
  .trust-item { display: flex; flex-direction: column; gap: 2px; }
  .trust-num {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--ink);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .trust-num .unit { font-size: 18px; color: var(--ink-muted); font-weight: 500; }
  .trust-label {
    font-size: 13px;
    color: var(--ink-muted);
    font-weight: 500;
    margin-top: 4px;
  }

  /* Phone mockup */
  .hero-visual {
    position: relative;
    z-index: 1;
    animation: fadeUp 1000ms var(--ease-smooth) 320ms both;
  }
  .phone {
    background: var(--ink);
    border-radius: 44px;
    padding: 12px;
    width: 360px;
    margin: 0 auto;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.05) inset,
      0 30px 60px -20px rgba(14, 14, 24, 0.4),
      0 50px 100px -40px rgba(14, 14, 24, 0.3);
    position: relative;
    z-index: 2;
    transform: rotate(-2deg);
    animation: phone-float 6s ease-in-out infinite;
  }
  @keyframes phone-float {
    0%, 100% { transform: rotate(-2deg) translateY(0); }
    50% { transform: rotate(-2deg) translateY(-12px); }
  }
  .phone-screen {
    background: var(--paper);
    border-radius: 32px;
    height: 660px;
    overflow: hidden;
    position: relative;
  }
  .phone-notch {
    position: absolute;
    top: 8px; left: 50%;
    transform: translateX(-50%);
    width: 100px; height: 28px;
    background: var(--ink);
    border-radius: 100px;
    z-index: 10;
  }
  .phone-status {
    padding: 16px 22px 8px;
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    font-family: var(--font-mono);
  }
  .phone-header {
    padding: 8px 22px 14px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .ph-greet-block { display: flex; flex-direction: column; }
  .ph-handle {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--ink-muted);
    letter-spacing: 0.04em;
    margin-bottom: 2px;
  }
  .ph-greeting {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .ph-bell {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--paper-elevated);
    border: 2px solid var(--ink);
    display: grid; place-items: center;
    position: relative;
  }
  .ph-bell svg { width: 16px; height: 16px; }
  .ph-bell::after {
    content: '';
    position: absolute;
    top: 4px; right: 4px;
    width: 8px; height: 8px;
    background: var(--coral);
    border: 1.5px solid var(--ink);
    border-radius: 50%;
  }
  .ph-balance {
    margin: 4px 16px 14px;
    background: var(--ink);
    color: var(--paper);
    border-radius: 22px;
    padding: 22px 20px 20px;
    position: relative;
    overflow: hidden;
    border: 2px solid var(--ink);
  }
  .ph-balance-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: rgba(246,242,233,0.55);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 6px;
    position: relative;
  }
  .ph-balance-amt {
    font-family: var(--font-display);
    font-size: 44px;
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1;
    margin-bottom: 14px;
    position: relative;
    font-variant-numeric: tabular-nums;
  }
  .ph-balance-amt .cents { font-size: 26px; color: rgba(246,242,233,0.6); }
  .ph-balance-amt .ccy {
    font-size: 14px;
    color: rgba(246,242,233,0.5);
    font-family: var(--font-mono);
    font-weight: 600;
    margin-left: 6px;
    letter-spacing: 0.05em;
  }
  .ph-earn-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--lime);
    color: var(--ink);
    padding: 5px 11px 5px 9px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 700;
    font-family: var(--font-mono);
    border: 1.5px solid var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .ph-earn-pill .live-tick {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--ink);
    animation: pulse 1.2s ease-in-out infinite;
  }
  .ph-actions {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    padding: 0 16px;
    margin-bottom: 16px;
  }
  .ph-action {
    background: var(--paper-elevated);
    border: 2px solid var(--ink);
    border-radius: 16px;
    padding: 14px 8px 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    box-shadow: 0 2px 0 var(--ink);
  }
  .ph-action-icon {
    width: 40px; height: 40px;
    border-radius: 12px;
    display: grid; place-items: center;
    border: 1.5px solid var(--ink);
  }
  .ph-action-icon svg { width: 18px; height: 18px; stroke-width: 2; }
  .ph-action-icon.send { background: var(--lime); }
  .ph-action-icon.receive { background: var(--sky); }
  .ph-action-icon.topup { background: var(--coral); color: var(--paper); }
  .ph-action-label {
    font-size: 12px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .ph-section-label {
    padding: 0 22px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
    margin-top: 4px;
  }
  .ph-activity-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 22px;
  }
  /* FLAT STICKER AVATARS — no gradients */
  .ph-act-avatar {
    width: 34px; height: 34px;
    border-radius: 50%;
    display: grid; place-items: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 13px;
    color: var(--ink);
    border: 1.5px solid var(--ink);
    flex-shrink: 0;
  }
  .ph-act-avatar.a1 { background: var(--coral); color: var(--paper); }
  .ph-act-avatar.a2 { background: var(--lime); color: var(--ink); }
  .ph-act-avatar.a3 { background: var(--sky); color: var(--ink); }
  .ph-act-info { flex: 1; min-width: 0; }
  .ph-act-name { font-size: 13px; font-weight: 700; color: var(--ink); line-height: 1.2; }
  .ph-act-meta { font-size: 11px; color: var(--ink-muted); margin-top: 1px; font-family: var(--font-mono); }
  .ph-act-amt {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: -0.02em;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }
  .ph-act-amt.in { color: var(--lime-deep); }
  .ph-act-amt.out { color: var(--ink); }

  .float-card {
    position: absolute;
    background: var(--paper-elevated);
    border: 2px solid var(--ink);
    border-radius: 14px;
    padding: 12px 14px;
    box-shadow: 0 4px 0 var(--ink);
    display: flex;
    align-items: center;
    gap: 10px;
    z-index: 5;
  }
  .float-card-1 { top: 60px; right: -10px; transform: rotate(4deg); animation: drift1 5s ease-in-out infinite; }
  .float-card-2 { bottom: 90px; left: -20px; transform: rotate(-4deg); animation: drift2 7s ease-in-out infinite; }
  @keyframes drift1 { 0%, 100% { transform: rotate(4deg) translateY(0); } 50% { transform: rotate(4deg) translateY(-10px); } }
  @keyframes drift2 { 0%, 100% { transform: rotate(-4deg) translateY(0); } 50% { transform: rotate(-4deg) translateY(-12px); } }
  .float-icon {
    width: 36px; height: 36px;
    border-radius: 10px;
    display: grid; place-items: center;
    border: 1.5px solid var(--ink);
  }
  .float-icon.lime { background: var(--lime); color: var(--ink); }
  .float-icon.coral { background: var(--coral); color: var(--ink); }
  .float-icon svg { width: 16px; height: 16px; stroke-width: 2.2; }
  .float-text { font-size: 13px; font-weight: 700; line-height: 1.2; font-family: var(--font-display); letter-spacing: -0.01em; }
  .float-sub { font-size: 11px; color: var(--ink-muted); font-weight: 500; margin-top: 2px; font-family: var(--font-mono); }

  /* USP grid */
  .why-us {
    padding: 120px 0 140px;
  }
  .usp-stack {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    max-width: 1080px;
    margin: 0 auto;
  }
  .usp-card {
    background: var(--paper-elevated);
    border: 2.5px solid var(--ink);
    border-radius: 24px;
    padding: 36px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 6px 0 var(--ink);
    transition: all 280ms var(--ease-spring);
  }
  .usp-card:hover {
    transform: translate(-2px, -4px);
    box-shadow: 0 10px 0 var(--ink);
  }
  .usp-card.featured {
    background: var(--ink);
    color: var(--paper);
    grid-column: span 2;
  }
  .usp-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    background: var(--lime);
    color: var(--ink);
    padding: 4px 10px;
    border-radius: 6px;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1.5px solid var(--ink);
  }
  .usp-tag .icon { width: 13px; height: 13px; stroke-width: 2.4; }
  .usp-headline {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.2vw, 42px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.025em;
    margin-bottom: 16px;
  }
  .usp-card.featured .usp-headline { font-size: clamp(32px, 4vw, 56px); }
  .usp-card.featured .usp-headline .stress { color: var(--lime); }
  .usp-card:not(.featured) .usp-headline .stress {
    color: var(--ink);
    position: relative;
  }
  .usp-card:not(.featured) .usp-headline .stress::after {
    content: '';
    position: absolute;
    left: -4%; right: -4%;
    bottom: 4%;
    height: 30%;
    background: var(--lime);
    z-index: -1;
    transform: skewX(-6deg);
    border-radius: 4px;
  }
  .usp-body {
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin-bottom: 0;
  }
  .usp-card.featured .usp-body { color: rgba(246,242,233,0.75); font-size: 18px; }
  .usp-vs {
    margin-top: 24px;
    padding-top: 20px;
    border-top: 2px dashed var(--line);
    display: flex;
    justify-content: space-between;
    gap: 20px;
    font-size: 13px;
  }
  .usp-card.featured .usp-vs { border-color: rgba(246,242,233,0.18); }
  .usp-vs > div { flex: 1; display: flex; flex-direction: column; gap: 4px; }
  .usp-vs-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }
  .usp-card.featured .usp-vs-label { color: rgba(246,242,233,0.5); }
  .usp-vs-val {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .usp-vs-val.them { color: var(--ink-muted); text-decoration: line-through; text-decoration-thickness: 2px; }
  .usp-card.featured .usp-vs-val.them { color: rgba(246,242,233,0.4); }
  .usp-vs-val.us { color: var(--ink); }
  .usp-card.featured .usp-vs-val.us { color: var(--lime); }

  /* How section (dark) */
  .how-section {
    padding: 120px 0 140px;
    background: var(--ink);
    color: var(--paper);
    position: relative;
    overflow: hidden;
  }
  .how-section .section-eyebrow {
    background: var(--lime);
    color: var(--ink);
    border-color: var(--lime);
    box-shadow: 0 2px 0 rgba(255,255,255,0.1);
  }
  .how-section .section-title { color: var(--paper); }
  .how-section .section-title .hl::before { background: var(--lime); }
  .how-section .section-title .hl { color: var(--ink); }
  .how-section .section-sub { color: rgba(246,242,233,0.7); }
  .how-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 26px 26px;
    pointer-events: none;
  }
  .how-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 60px;
    position: relative;
  }
  .how-step {
    background: rgba(255,255,255,0.03);
    border: 2px solid rgba(255,255,255,0.1);
    border-radius: 24px;
    padding: 32px;
    position: relative;
    transition: all 280ms var(--ease-spring);
  }
  .how-step:hover {
    border-color: var(--lime);
    background: rgba(200, 241, 84, 0.06);
    transform: translateY(-4px);
  }
  .how-num {
    font-family: var(--font-display);
    font-size: 80px;
    font-weight: 700;
    line-height: 0.85;
    color: var(--lime);
    margin-bottom: 16px;
    letter-spacing: -0.04em;
  }
  .how-icon {
    position: absolute;
    top: 32px; right: 32px;
    width: 44px; height: 44px;
    border-radius: 12px;
    background: rgba(200, 241, 84, 0.1);
    border: 1.5px solid rgba(200, 241, 84, 0.3);
    display: grid;
    place-items: center;
    color: var(--lime);
  }
  .how-icon svg { width: 20px; height: 20px; stroke-width: 2; }
  .how-title {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }
  .how-desc { font-size: 15.5px; line-height: 1.55; color: rgba(246,242,233,0.7); }
  .how-tag {
    display: inline-block;
    margin-top: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--lime);
    background: rgba(200, 241, 84, 0.08);
    padding: 4px 10px;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border: 1px solid rgba(200, 241, 84, 0.2);
  }

  /* Earn section */
  .earn-section {
    padding: 120px 0;
    position: relative;
    overflow: hidden;
  }
  .earn-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .earn-card {
    background: var(--ink);
    color: var(--paper);
    border-radius: 32px;
    padding: 48px;
    border: 3px solid var(--ink);
    box-shadow: 0 10px 0 var(--lime);
    position: relative;
    overflow: hidden;
    transform: rotate(-1.5deg);
    transition: transform 400ms var(--ease-spring);
  }
  .earn-card:hover { transform: rotate(0); }
  .earn-card-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--lime);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .earn-card-eyebrow .live {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--lime);
    animation: pulse 1.4s ease-in-out infinite;
    box-shadow: 0 0 12px var(--lime);
  }
  .earn-ticker {
    font-family: var(--font-display);
    font-size: clamp(56px, 7.5vw, 96px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--lime);
    margin-bottom: 14px;
    text-shadow: 0 0 60px rgba(200, 241, 84, 0.4);
    font-variant-numeric: tabular-nums;
  }
  .earn-ticker .symbol { color: rgba(200, 241, 84, 0.6); font-size: 0.65em; vertical-align: top; margin-right: 2px; }
  .earn-rate-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--lime);
    color: var(--ink);
    padding: 8px 14px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 700;
    font-family: var(--font-mono);
    border: 2px solid var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    box-shadow: 0 2px 0 rgba(255,255,255,0.15);
    margin-bottom: 32px;
  }
  .earn-rate-pill .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--ink);
    animation: pulse 1.4s ease-in-out infinite;
  }
  .earn-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: rgba(246,242,233,0.15);
    border-radius: 18px;
    overflow: hidden;
    border: 2px solid rgba(246,242,233,0.15);
  }
  .earn-stat { background: rgba(255,255,255,0.03); padding: 22px 24px; }
  .earn-stat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: rgba(246,242,233,0.55);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .earn-stat-label .live {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--lime);
    animation: pulse 1.2s ease-in-out infinite;
    box-shadow: 0 0 6px var(--lime);
  }
  .earn-stat-num {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .earn-copy h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 700;
    line-height: 0.96;
    letter-spacing: -0.035em;
    margin-bottom: 24px;
  }
  .earn-copy p {
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin-bottom: 20px;
    max-width: 520px;
  }
  .earn-bullets { list-style: none; margin-top: 28px; }
  .earn-bullets li {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 12px 0;
    border-bottom: 1.5px dashed var(--line);
    font-size: 16px;
    line-height: 1.45;
    color: var(--ink-soft);
  }
  .earn-bullets li:last-child { border-bottom: none; }
  .earn-bullets .check {
    flex-shrink: 0;
    width: 28px; height: 28px;
    background: var(--lime);
    border: 2px solid var(--ink);
    border-radius: 8px;
    display: grid; place-items: center;
    box-shadow: 0 2px 0 var(--ink);
    transform: rotate(-3deg);
  }
  .earn-bullets li:nth-child(2) .check { background: var(--coral); transform: rotate(2deg); }
  .earn-bullets li:nth-child(3) .check { background: var(--sky); transform: rotate(-2deg); }
  .earn-bullets .check svg { width: 14px; height: 14px; stroke: var(--ink); stroke-width: 3; }
  .earn-bullets strong { color: var(--ink); font-weight: 700; }

  /* Statement section */
  .statement-section {
    padding: 140px 0;
    text-align: center;
    background: var(--paper-deep);
    position: relative;
  }
  .statement-block { max-width: 1000px; margin: 0 auto; }
  .big-quote {
    font-family: var(--font-display);
    font-size: clamp(56px, 8vw, 116px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin-bottom: 40px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
  }
  .big-quote .word {
    display: inline-block;
    padding: 0 20px;
    border: 3px solid var(--ink);
    border-radius: 14px;
    box-shadow: 0 6px 0 var(--ink);
    color: var(--ink);
  }
  .big-quote .w-lime { background: var(--lime); transform: rotate(-1.5deg); }
  .big-quote .w-coral { background: var(--coral); color: var(--paper); transform: rotate(1.5deg); }
  .big-quote .w-sky { background: var(--sky); transform: rotate(-1deg); }

  .statement-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--ink);
    border: 2.5px solid var(--ink);
    border-radius: 24px;
    overflow: hidden;
    max-width: 880px;
    margin: 60px auto 0;
    box-shadow: 0 6px 0 var(--ink);
  }
  .ss-cell {
    background: var(--paper-elevated);
    padding: 36px 24px;
    text-align: center;
  }
  .ss-num {
    font-family: var(--font-display);
    font-size: 48px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: 6px;
    font-variant-numeric: tabular-nums;
  }
  .ss-num .unit { color: var(--ink-muted); font-size: 26px; }
  .ss-label { font-size: 14px; color: var(--ink-muted); font-weight: 500; line-height: 1.3; }

  /* Trust section */
  .trust-section { padding: 120px 0; }
  .trust-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .trust-section-copy h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 700;
    line-height: 0.96;
    letter-spacing: -0.035em;
    margin-bottom: 24px;
  }
