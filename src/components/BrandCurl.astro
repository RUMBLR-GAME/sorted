---
interface Props {
  size?: string;
  color?: string;
  rotate?: number;
  class?: string;
  drift?: boolean;
  parallax?: boolean;
}
const {
  size,
  color = 'var(--lime)',
  rotate = 0,
  class: className = '',
  drift = false,
  parallax = false,
} = Astro.props;

const styleParts = [
  `color: ${color}`,
  `--curl-rotate: ${rotate}deg`,
];
if (size) {
  styleParts.unshift(`width: ${size}`, `height: ${size}`);
}
const styleStr = styleParts.join('; ');
---

<div
  class:list={['brand-curl', className, { 'brand-curl--drift': drift, 'brand-curl--parallax': parallax }]}
  style={styleStr}
  data-base-rotate={rotate}
  aria-hidden="true"
>
  <svg viewBox="0 0 379.48 398.12" xmlns="http://www.w3.org/2000/svg">
    <path
      fill="currentColor"
      d="M177.08,181.22c-5.59,2.64-10.84,1.2-13.22-3.75s.13-10.97,5.92-12.7l18.37-5.48,21.92-50.27c3.26-7.47.81-15.3-4.95-19.94-5.45-4.38-16.23-5.85-21.22,1.1-20.06,27.96-49.09,79.23-52.38,112.16-3.46,34.62-2.15,68.62-1.06,103.33.17,5.42-3.44,9.06-8.24,9.37s-9.28-3.67-9.45-9.32l-.75-74.74c-5.91-15.67-9.48-31.21-11.89-48.17-2.76-28.86-4.4-57.38-1.1-86.17,1.68-14.64,14.96-24.45,27.24-26.37,15.16-2.38,28.98,4.55,36.82,18.98,8.32-17.52,26.26-25.77,43.7-19.26s27.82,25.68,20.4,43.1l-19.51,45.83c21.67,3.07,39.81,13.42,52.17,30.27,8.15,11.11,7.61,25.77-.55,37.15,13.6,9.93,16.99,26.13,10.38,40.94-8.62,19.33-23.73,33.67-43.27,41.86-2.03,4.36-6.28,6.46-9.97,5.91-5.11-1.35-7.41-5.26-7.46-10.51-.06-5.56,2.47-9.44,7.6-11,17.09-5.18,29.86-17.78,37.12-33.85,3.47-7.69,1.1-16.32-6.42-19.91s-16.43.13-19.63,8.32c-7.22,18.45-29.03,25.38-45.45,15.8-16.95-9.89-21.01-32.78-8.65-47.77,12.53-15.19,35.94-15.8,48.87-.3,5.57,6.67,15.05,7.48,21.04,1.82,6.71-6.33,5.4-15.46-.82-21.99-16.94-17.78-42.4-25.35-65.56-14.41ZM148.03,113.58c.73-3.7.68-10.17,0-13.1-1.95-8.44-8.54-12.82-16.19-12.95-6.01-.1-14.75,4.12-15.46,11.86-2.41,26.26-1.89,52,1.36,79.75,8.36-22.87,17.53-43.96,30.28-65.56ZM215.3,233.35l-7.78-7.46c-6.54-6.27-16.57-4.41-21.3,2.84-4.34,6.65-2.11,15.92,5.07,19.96s15.99,1.37,19.74-6.45l4.27-8.9Z"
    />
  </svg>
</div>

<style>
  .brand-curl {
    position: absolute;
    pointer-events: none;
    will-change: transform;
    --curl-rotate: 0deg;
    transform: rotate(var(--curl-rotate));
  }
  .brand-curl svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  /* Slow continuous drift — applied to inner SVG so wrapper transform stays free */
  .brand-curl--drift svg {
    animation: brand-curl-drift 32s ease-in-out infinite;
    transform-origin: 50% 50%;
  }
  @keyframes brand-curl-drift {
    0%, 100% { transform: rotate(-2deg) scale(1); }
    50%      { transform: rotate(2deg) scale(1.025); }
  }
</style>
